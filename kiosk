<!DOCTYPE html>

<html lang="id">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Absensi Kiosk — Sido Muncul</title>
<link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;600;700;800;900&display=swap" rel="stylesheet">
<style>
:root {
  --primary: #059669;
  --primary-dark: #047857;
  --primary-light: #d1fae5;
  --bg: #f1f5f9;
  --white: #fff;
  --text: #0f172a;
  --muted: #64748b;
  --border: #e2e8f0;
  --red: #ef4444;
}
* { box-sizing: border-box; margin: 0; padding: 0; }
body { font-family: 'Plus Jakarta Sans', sans-serif; background: var(--bg); min-height: 100vh; }

/* HEADER */
.header { background: white; border-bottom: 1px solid var(–border); padding: 11px 18px; display: flex; align-items: center; justify-content: space-between; position: sticky; top: 0; z-index: 50; box-shadow: 0 1px 6px rgba(0,0,0,0.05); }
.header-left { display: flex; align-items: center; gap: 11px; }
.brand-icon { width: 36px; height: 36px; background: linear-gradient(135deg,#3a6b1a,#059669); border-radius: 9px; display: flex; align-items: center; justify-content: center; flex-shrink: 0; }
.brand-icon svg { width: 19px; height: 19px; }
.h-topik { font-size: 14px; font-weight: 900; color: var(–text); }
.h-meta { font-size: 10px; color: var(–muted); font-weight: 500; margin-top: 1px; }
.status-pill { display: flex; align-items: center; gap: 5px; background: var(–primary-light); border: 1px solid #6ee7b7; border-radius: 20px; padding: 5px 11px; font-size: 11px; font-weight: 800; color: #065f46; }
.status-dot { width: 7px; height: 7px; background: var(–primary); border-radius: 50%; animation: pulse 1.5s infinite; }
@keyframes pulse { 0%,100%{opacity:1;transform:scale(1)} 50%{opacity:0.5;transform:scale(0.8)} }
.live-clock { font-size: 12px; font-weight: 700; color: var(–muted); background: #f8fafc; border: 1px solid var(–border); border-radius: 7px; padding: 4px 10px; }

/* LAYOUT */
.layout { display: grid; grid-template-columns: 1fr 360px; gap: 14px; padding: 14px 18px 80px; max-width: 1060px; margin: 0 auto; }

/* INFO CARD */
.info-card { background: white; border-radius: 14px; padding: 16px; border: 1px solid var(–border); margin-bottom: 12px; }
.ic-title { font-size: 10px; font-weight: 900; color: var(–muted); text-transform: uppercase; letter-spacing: 1px; margin-bottom: 12px; }
.info-row { display: grid; grid-template-columns: 90px 1fr; gap: 5px; align-items: flex-start; padding: 7px 0; border-bottom: 1px solid #f8fafc; }
.info-row:last-child { border-bottom: none; }
.ir-lbl { font-size: 9.5px; font-weight: 800; color: var(–muted); text-transform: uppercase; letter-spacing: 0.3px; padding-top: 1px; }
.ir-val { font-size: 12px; font-weight: 700; color: var(–text); }
.ir-val.hi { color: var(–primary); }

/* COUNTER */
.counter { background: linear-gradient(135deg, var(–primary), #10b981); border-radius: 14px; padding: 16px 18px; color: white; margin-bottom: 12px; position: relative; overflow: hidden; }
.counter::before { content:’’; position:absolute; top:-20px; right:-20px; width:90px; height:90px; background:rgba(255,255,255,0.08); border-radius:50%; }
.c-lbl { font-size: 9.5px; font-weight: 800; letter-spacing: 1.5px; text-transform: uppercase; opacity: 0.8; margin-bottom: 3px; }
.c-row { display: flex; align-items: flex-end; gap: 10px; }
.c-num { font-size: 44px; font-weight: 900; line-height: 1; }
.c-from { font-size: 13px; opacity: 0.7; font-weight: 700; padding-bottom: 7px; }
.c-pct { font-size: 10px; opacity: 0.75; font-weight: 600; margin-top: 3px; }

/* LOG */
.log-card { background: white; border-radius: 14px; border: 1px solid var(–border); overflow: hidden; }
.log-hdr { padding: 12px 14px; border-bottom: 1px solid var(–border); display: flex; align-items: center; justify-content: space-between; }
.log-title { font-size: 12px; font-weight: 800; }
.log-badge { font-size: 9.5px; font-weight: 800; background: var(–primary-light); color: var(–primary); padding: 2px 8px; border-radius: 20px; }
.log-list { max-height: 320px; overflow-y: auto; }
.log-item { display: flex; align-items: center; gap: 9px; padding: 9px 14px; border-bottom: 1px solid #f8fafc; animation: sIn 0.3s ease both; }
.log-item:last-child { border-bottom: none; }
@keyframes sIn { from{opacity:0;transform:translateX(-10px)} to{opacity:1;transform:translateX(0)} }
.log-av { width: 32px; height: 32px; border-radius: 8px; background: var(–primary-light); color: var(–primary); display: flex; align-items: center; justify-content: center; font-weight: 900; font-size: 12px; flex-shrink: 0; }
.log-name { font-size: 11.5px; font-weight: 800; }
.log-unit { font-size: 9.5px; color: var(–muted); font-weight: 600; margin-top: 1px; }
.log-time { font-size: 10.5px; font-weight: 700; color: var(–primary); white-space: nowrap; margin-left: auto; }

/* FORM */
.form-card { background: white; border-radius: 16px; padding: 20px; border: 1px solid var(–border); box-shadow: 0 4px 18px rgba(0,0,0,0.06); position: sticky; top: 68px; }
.fc-title { font-size: 15px; font-weight: 900; margin-bottom: 3px; }
.fc-sub { font-size: 11px; color: var(–muted); font-weight: 600; margin-bottom: 18px; }
.fg { margin-bottom: 13px; }
.fl { font-size: 10px; font-weight: 800; color: var(–muted); text-transform: uppercase; letter-spacing: 0.5px; margin-bottom: 5px; display: block; }
.nik-wrap { position: relative; }
.nik-icon { position: absolute; left: 11px; top: 50%; transform: translateY(-50%); width: 15px; height: 15px; color: #cbd5e1; pointer-events: none; }
.nik-input { width: 100%; padding: 11px 12px 11px 35px; border-radius: 10px; border: 2px solid var(–border); font-size: 15px; font-weight: 700; font-family: inherit; outline: none; background: #f8fafc; transition: 0.2s; letter-spacing: 1px; color: var(–text); }
.nik-input:focus { border-color: var(–primary); background: white; box-shadow: 0 0 0 3px rgba(5,150,105,0.1); }
.paraf-wrap { border: 2px solid var(–border); border-radius: 10px; overflow: hidden; background: #fafafa; transition: 0.15s; margin-bottom: 13px; }
.paraf-wrap:hover { border-color: var(–primary); }
.paraf-top { padding: 6px 11px; background: #f8fafc; border-bottom: 1px solid var(–border); display: flex; align-items: center; justify-content: space-between; }
.paraf-lbl { font-size: 9.5px; font-weight: 800; color: var(–muted); text-transform: uppercase; letter-spacing: 0.5px; }
.btn-clear { padding: 3px 9px; border-radius: 5px; border: 1px solid var(–border); background: white; font-size: 10.5px; font-weight: 700; color: var(–muted); cursor: pointer; font-family: inherit; transition: 0.15s; }
.btn-clear:hover { background: #fee2e2; color: var(–red); }
#paraf-canvas { display: block; cursor: crosshair; touch-action: none; width: 100%; height: 110px; background: white; }
.btn-submit { width: 100%; padding: 12px; border-radius: 11px; background: linear-gradient(135deg, var(–primary), #10b981); color: white; font-size: 13.5px; font-weight: 900; border: none; cursor: pointer; font-family: inherit; transition: all 0.2s; display: flex; align-items: center; justify-content: center; gap: 8px; box-shadow: 0 4px 14px rgba(5,150,105,0.3); letter-spacing: 0.3px; }
.btn-submit:hover { transform: translateY(-1px); box-shadow: 0 6px 18px rgba(5,150,105,0.4); }
.btn-submit:disabled { opacity: 0.6; cursor: not-allowed; transform: none; }
.spinner { width: 17px; height: 17px; border: 2.5px solid rgba(255,255,255,0.3); border-top-color: white; border-radius: 50%; animation: spin 0.7s linear infinite; display: none; }
@keyframes spin { to { transform: rotate(360deg); } }

/* ERROR */
.err-box { background: #fee2e2; border: 1px solid #fca5a5; border-radius: 9px; padding: 10px 12px; font-size: 12px; font-weight: 700; color: #991b1b; display: none; align-items: center; gap: 6px; margin-bottom: 12px; animation: shake 0.4s ease; }
@keyframes shake { 0%,100%{transform:translateX(0)} 20%{transform:translateX(-5px)} 40%{transform:translateX(5px)} 60%{transform:translateX(-3px)} 80%{transform:translateX(3px)} }

/* SUCCESS */
.success-area { display: none; flex-direction: column; align-items: center; justify-content: center; padding: 24px 16px; text-align: center; animation: bIn 0.3s ease; }
@keyframes bIn { from{opacity:0;transform:scale(0.95)} to{opacity:1;transform:scale(1)} }
.success-circle { width: 68px; height: 68px; background: var(–primary-light); border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 30px; margin-bottom: 12px; animation: bounce 0.5s cubic-bezier(0.34,1.56,0.64,1); }
@keyframes bounce { from{transform:scale(0.3)} to{transform:scale(1)} }
.s-name { font-size: 19px; font-weight: 900; margin-bottom: 3px; }
.s-nik  { font-size: 12px; color: var(–muted); font-weight: 600; margin-bottom: 7px; }
.s-time { font-size: 13px; font-weight: 800; color: var(–primary); margin-bottom: 3px; }
.s-unit { font-size: 11px; color: var(–muted); font-weight: 600; }
.cdown-bar { width: 100%; height: 3px; background: #f1f5f9; border-radius: 20px; margin-top: 16px; overflow: hidden; }
.cdown-fill { height: 100%; background: linear-gradient(90deg, var(–primary), #10b981); border-radius: 20px; animation: cdown 3s linear forwards; }
@keyframes cdown { from{width:100%} to{width:0%} }

/* EXIT */
.exit-btn { position: fixed; bottom: 18px; right: 18px; background: #1e293b; color: white; border: none; border-radius: 11px; padding: 9px 14px; font-size: 11.5px; font-weight: 800; cursor: pointer; font-family: inherit; display: flex; align-items: center; gap: 6px; box-shadow: 0 4px 14px rgba(0,0,0,0.25); transition: 0.2s; z-index: 100; }
.exit-btn:hover { background: #0f172a; transform: translateY(-1px); }
.overlay { display: none; position: fixed; inset: 0; background: rgba(0,0,0,0.4); backdrop-filter: blur(4px); z-index: 500; align-items: center; justify-content: center; padding: 16px; }
.overlay.show { display: flex; }
.exit-modal { background: white; border-radius: 18px; padding: 26px; width: 100%; max-width: 340px; animation: mIn 0.25s ease; text-align: center; }
@keyframes mIn { from{opacity:0;transform:scale(0.95) translateY(8px)} to{opacity:1;transform:scale(1) translateY(0)} }
.em-icon { font-size: 34px; margin-bottom: 10px; }
.em-title { font-size: 16px; font-weight: 900; margin-bottom: 6px; }
.em-sub { font-size: 12px; color: var(–muted); margin-bottom: 18px; line-height: 1.6; }
.em-pw { width: 100%; padding: 10px; border-radius: 10px; border: 2px solid var(–border); font-size: 15px; font-weight: 700; font-family: inherit; outline: none; text-align: center; letter-spacing: 4px; transition: 0.15s; margin-bottom: 8px; }
.em-pw:focus { border-color: var(–red); }
.em-err { font-size: 11px; color: var(–red); font-weight: 700; margin-bottom: 10px; display: none; }
.em-btns { display: flex; gap: 8px; }
.btn-em-cancel { flex: 1; padding: 10px; border-radius: 9px; background: #f1f5f9; border: 1px solid var(–border); font-size: 12px; font-weight: 700; cursor: pointer; color: var(–muted); font-family: inherit; }
.btn-em-ok { flex: 1; padding: 10px; border-radius: 9px; background: var(–red); color: white; font-size: 12px; font-weight: 800; border: none; cursor: pointer; font-family: inherit; }

/* RESPONSIVE */
@media(max-width:700px){
.layout{grid-template-columns:1fr;padding:12px 14px 80px;}
.form-card{position:static;}
.header{flex-wrap:wrap;gap:8px;}
}
</style>

