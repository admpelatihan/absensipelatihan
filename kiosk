<script>
// ==================== KONFIGURASI ====================
var GAS_URL  = "https://script.google.com/macros/s/AKfycbzqbR0ySliaMyXuAEAiw6QnAHuIyBvaqT40mAWV1y2mV7_gdaKCDqACKF7Ct0EJcZtI/exec";
var BASE_URL = window.location.href.replace('kiosk.html','');

// Ambil ID pelatihan dari URL: kiosk.html?id=PLT-XXXXX
var PEL_ID = new URLSearchParams(window.location.search).get('id') || '';
var hadirList = [];
var totalPeserta = 0;
var retryLoad = 0, retryAbsen = 0, retryExit = 0;

// ==================== CLOCK ====================
setInterval(function() {
  var n = new Date();
  document.getElementById('clock').textContent =
    ('0'+n.getHours()).slice(-2)+':'+('0'+n.getMinutes()).slice(-2)+':'+('0'+n.getSeconds()).slice(-2);
}, 1000);

// ==================== FORMAT TANGGAL ====================
function fmtTgl(v) {
  if (!v) return '-'; var d = new Date(v); if (isNaN(d)) return v;
  var h = ['Minggu','Senin','Selasa','Rabu','Kamis','Jumat','Sabtu'][d.getDay()];
  var b = ['Jan','Feb','Mar','Apr','Mei','Jun','Jul','Agu','Sep','Okt','Nov','Des'][d.getMonth()];
  return h + ' / ' + d.getDate() + ' ' + b + ' ' + d.getFullYear();
}

// ==================== LOAD DATA PELATIHAN ====================
function loadPelatihan() {
  if (!PEL_ID) { document.getElementById('h-topik').textContent = 'Link tidak valid.'; return; }
  fetch(GAS_URL, {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ action: 'getPelatihanPublic', pelatihanId: PEL_ID })
  })
  .then(function(r) { return r.json(); })
  .then(function(res) {
    retryLoad = 0;
    if (res.success) {
      var d = res.data;
      document.getElementById('h-topik').textContent = d.Topik || 'Pelatihan';
      document.getElementById('h-meta').textContent  = (d.Penyelenggara||'HR-MI') + ' · ' + fmtTgl(d.TanggalPelatihan);
      document.getElementById('i-tgl').textContent         = fmtTgl(d.TanggalPelatihan);
      document.getElementById('i-waktu').textContent       = (d.WaktuMulai||'-') + ' – ' + (d.WaktuSelesai||'-');
      document.getElementById('i-lokasi').textContent      = d.Lokasi || '-';
      document.getElementById('i-instruktur').textContent  = d.Instruktur || '-';
      document.getElementById('i-penyelenggara').textContent = d.Penyelenggara || 'HR-MI';
      document.getElementById('info-card').style.display = 'block';
    } else {
      document.getElementById('h-topik').textContent = 'Pelatihan tidak ditemukan.';
    }
  })
  .catch(function() {
    retryLoad++;
    if (retryLoad <= 3) setTimeout(loadPelatihan, 1500 * retryLoad);
  });
}
loadPelatihan();

// ==================== CANVAS PARAF ====================
var canvas = document.getElementById('paraf-canvas');
var ctx    = canvas.getContext('2d');
var drawing = false, lx = 0, ly = 0;

function resizeCanvas() { canvas.width = canvas.offsetWidth; canvas.height = 110; }
resizeCanvas();
window.addEventListener('resize', resizeCanvas);

ctx.strokeStyle = '#1e293b'; ctx.lineWidth = 2.5; ctx.lineCap = 'round'; ctx.lineJoin = 'round';

function pos(e) {
  var r = canvas.getBoundingClientRect();
  var s = e.touches ? e.touches[0] : e;
  return { x: s.clientX - r.left, y: s.clientY - r.top };
}
canvas.addEventListener('mousedown',  function(e){ drawing=true; var p=pos(e); lx=p.x; ly=p.y; });
canvas.addEventListener('mousemove',  function(e){ if(!drawing)return; var p=pos(e); ctx.beginPath(); ctx.moveTo(lx,ly); ctx.lineTo(p.x,p.y); ctx.stroke(); lx=p.x; ly=p.y; });
canvas.addEventListener('mouseup',    function(){ drawing=false; });
canvas.addEventListener('mouseleave', function(){ drawing=false; });
canvas.addEventListener('touchstart', function(e){ e.preventDefault(); drawing=true; var p=pos(e); lx=p.x; ly=p.y; });
canvas.addEventListener('touchmove',  function(e){ e.preventDefault(); if(!drawing)return; var p=pos(e); ctx.beginPath(); ctx.moveTo(lx,ly); ctx.lineTo(p.x,p.y); ctx.stroke(); lx=p.x; ly=p.y; });
canvas.addEventListener('touchend',   function(){ drawing=false; });
function clearParaf() { ctx.clearRect(0, 0, canvas.width, canvas.height); }

// ==================== RENDER LOG ====================
function renderLog() {
  var n = hadirList.length;
  document.getElementById('c-num').textContent    = n;
  document.getElementById('c-from').textContent   = '/ ' + (totalPeserta || '—') + ' peserta';
  document.getElementById('c-pct').textContent    = totalPeserta ? (n/totalPeserta*100).toFixed(1)+'%' : '0%';
  document.getElementById('log-badge').textContent = n + ' hadir';

  if (!n) { document.getElementById('log-list').innerHTML = '<div style="text-align:center;padding:20px;color:var(--muted);font-size:12px">Belum ada absensi.</div>'; return; }
  document.getElementById('log-list').innerHTML = [...hadirList].reverse().map(function(p) {
    var init = (p.nama||'?').split(' ').map(function(w){return w[0]||'';}).join('').substring(0,2).toUpperCase();
    return '<div class="log-item">' +
      '<div class="log-av">'+init+'</div>' +
      '<div style="flex:1;min-width:0"><div class="log-name">'+p.nama+'</div><div class="log-unit">'+p.unit+' · NIK: '+p.nik+'</div></div>' +
      '<div class="log-time">'+p.jam+'</div></div>';
  }).join('');
}

// ==================== SUBMIT ABSEN ====================
function setLoading(v) {
  document.getElementById('btn-submit').disabled      = v;
  document.getElementById('btn-txt').style.display    = v ? 'none' : 'inline';
  document.getElementById('spinner').style.display    = v ? 'inline-block' : 'none';
}
function showErr(msg) {
  var b = document.getElementById('err-box');
  document.getElementById('err-msg').textContent = msg;
  b.style.display = 'flex'; b.style.animation = 'none';
  b.offsetHeight; b.style.animation = 'shake 0.4s ease';
}

function submitAbsen() {
  var nik = document.getElementById('nik-input').value.trim();
  document.getElementById('err-box').style.display = 'none';
  if (!nik) { showErr('NIK wajib diisi.'); return; }
  var isEmpty = !ctx.getImageData(0,0,canvas.width,canvas.height).data.some(function(v){return v!==0;});
  var paraf = isEmpty ? '' : canvas.toDataURL('image/png');
  setLoading(true);

  fetch(GAS_URL, {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({
      action: 'absenKiosk',
      pelatihanId: PEL_ID,
      nik: nik,
      paraf: paraf,
      deviceInfo: navigator.userAgent.substring(0, 100)
    })
  })
  .then(function(r) { return r.json(); })
  .then(function(res) {
    setLoading(false); retryAbsen = 0;
    if (res.success) {
      var d = res.data;
      var now = new Date();
      var jam = ('0'+now.getHours()).slice(-2)+':'+('0'+now.getMinutes()).slice(-2);
      hadirList.push({ nik: nik, nama: d.nama||nik, unit: d.unit||'-', jam: jam });
      renderLog();
      // Tampilkan sukses
      document.getElementById('s-name').textContent = d.nama || nik;
      document.getElementById('s-nik').textContent  = 'NIK: ' + nik;
      document.getElementById('s-time').textContent = '✅ Absensi tercatat pukul ' + (d.waktu||jam) + ' WIB';
      document.getElementById('s-unit').textContent = d.unit || '-';
      document.getElementById('form-area').style.display   = 'none';
      document.getElementById('success-area').style.display = 'flex';
      // Reset countdown
      var fill = document.getElementById('cdown-fill');
      fill.style.animation = 'none'; fill.offsetHeight;
      fill.style.animation = 'cdown 3s linear forwards';
      setTimeout(function() {
        document.getElementById('success-area').style.display = 'none';
        document.getElementById('form-area').style.display    = 'block';
        document.getElementById('nik-input').value = '';
        clearParaf();
        document.getElementById('nik-input').focus();
      }, 3000);
    } else {
      showErr(res.message || 'Absensi gagal.');
    }
  })
  .catch(function() {
    retryAbsen++;
    if (retryAbsen <= 3) { setTimeout(submitAbsen, 1200 * retryAbsen); }
    else { setLoading(false); retryAbsen = 0; showErr('Koneksi gagal. Coba lagi.'); }
  });
}

document.getElementById('nik-input').addEventListener('keydown', function(e) {
  if (e.key === 'Enter') submitAbsen();
});

// ==================== EXIT KIOSK ====================
function openExit()  { document.getElementById('ov-exit').classList.add('show'); document.getElementById('exit-pw').focus(); }
function closeExit() { document.getElementById('ov-exit').classList.remove('show'); document.getElementById('exit-pw').value=''; document.getElementById('exit-err').style.display='none'; }

function confirmExit() {
  var pw = document.getElementById('exit-pw').value;
  if (!pw) { document.getElementById('exit-err').textContent='Password wajib diisi.'; document.getElementById('exit-err').style.display='block'; return; }
  fetch(GAS_URL, {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ action: 'exitKiosk', pelatihanId: PEL_ID, password: pw })
  })
  .then(function(r) { return r.json(); })
  .then(function(res) {
    retryExit = 0;
    if (res.success) { closeExit(); window.close(); setTimeout(function(){ window.location.href = BASE_URL + 'app.html'; }, 400); }
    else { document.getElementById('exit-err').textContent = res.message || 'Password salah.'; document.getElementById('exit-err').style.display = 'block'; }
  })
  .catch(function() {
    retryExit++;
    if (retryExit <= 3) setTimeout(confirmExit, 1200 * retryExit);
    else { retryExit=0; document.getElementById('exit-err').textContent='Koneksi gagal.'; document.getElementById('exit-err').style.display='block'; }
  });
}

document.getElementById('exit-pw').addEventListener('keydown', function(e){ if(e.key==='Enter') confirmExit(); });
document.getElementById('ov-exit').addEventListener('click', function(e){ if(e.target===this) closeExit(); });
</script>

