<script>
// ==================== KONFIGURASI ====================
var GAS_URL = "https://script.google.com/macros/s/AKfycbzqbR0ySliaMyXuAEAiw6QnAHuIyBvaqT40mAWV1y2mV7_gdaKCDqACKF7Ct0EJcZtI/exec";
var retryCount = 0;
var MAX_RETRY  = 3;

// ==================== CEK SESI AKTIF ====================
(function() {
  var sid  = localStorage.getItem('sm_sid');
  var exp  = localStorage.getItem('sm_exp');
  if (sid && exp && Date.now() < parseInt(exp)) {
    window.location.href = 'app.html';
  }
})();

// ==================== TOGGLE PASSWORD ====================
function togglePw() {
  var el  = document.getElementById('password');
  var eye = document.getElementById('pw-eye');
  if (el.type === 'password') { el.type = 'text';     eye.textContent = '🙈'; }
  else                        { el.type = 'password'; eye.textContent = '👁'; }
}

// ==================== ENTER KEY ====================
document.addEventListener('keydown', function(e) {
  if (e.key === 'Enter') doLogin();
});

// ==================== SHOW ERROR ====================
function showError(msg) {
  var box = document.getElementById('error-box');
  document.getElementById('error-msg').textContent = msg;
  box.style.display = 'flex';
  box.style.animation = 'none';
  box.offsetHeight;
  box.style.animation = 'shake 0.4s ease';
}

// ==================== LOADING ====================
function setLoading(v) {
  document.getElementById('btn-login').disabled       = v;
  document.getElementById('btn-text').style.display   = v ? 'none' : 'inline';
  document.getElementById('spinner').style.display    = v ? 'inline-block' : 'none';
}

// ==================== LOGIN ====================
function doLogin() {
  var u = document.getElementById('username').value.trim();
  var p = document.getElementById('password').value;

  document.getElementById('error-box').style.display = 'none';
  document.getElementById('retry-info').style.display = 'none';

  if (!u || !p) {
    showError('Username dan password wajib diisi.');
    return;
  }

  setLoading(true);

  fetch(GAS_URL, {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ action: 'login', username: u, password: p })
  })
  .then(function(r) { return r.json(); })
  .then(function(res) {
    setLoading(false);
    retryCount = 0;
    document.getElementById('retry-info').style.display = 'none';

    if (res.success) {
      // Simpan sesi di localStorage
      localStorage.setItem('sm_sid',    res.data.sessionId);
      localStorage.setItem('sm_role',   res.data.role);
      localStorage.setItem('sm_nama',   res.data.nama);
      localStorage.setItem('sm_userId', res.data.userId);
      localStorage.setItem('sm_unit',   res.data.unitKerja || '');
      // Expired 12 jam dari sekarang
      localStorage.setItem('sm_exp', String(Date.now() + 12 * 60 * 60 * 1000));
      // Redirect ke dashboard
      window.location.href = 'app.html';
    } else {
      showError(res.message || 'Login gagal. Periksa username dan password.');
    }
  })
  .catch(function() {
    retryCount++;
    if (retryCount <= MAX_RETRY) {
      document.getElementById('retry-info').style.display = 'block';
      setTimeout(doLogin, 1500 * retryCount);
    } else {
      setLoading(false);
      retryCount = 0;
      document.getElementById('retry-info').style.display = 'none';
      showError('Koneksi gagal setelah ' + MAX_RETRY + ' percobaan. Cek koneksi internet Anda.');
    }
  });
}
</script>

