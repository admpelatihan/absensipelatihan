<title>Login — E-Attendance Sido Muncul</title>
<link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">
<style>
:root {
  --primary: #059669;
  --primary-dark: #047857;
  --bg: #f1f5f9;
  --white: #fff;
  --text: #0f172a;
  --muted: #64748b;
  --border: #e2e8f0;
  --red: #ef4444;
}
* { box-sizing: border-box; margin: 0; padding: 0; }
body {
  font-family: 'Plus Jakarta Sans', sans-serif;
  background: var(--bg);
  min-height: 100vh;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 16px;
}
/* Background dekoratif */
body::before {
  content: '';
  position: fixed;
  top: -100px; right: -100px;
  width: 400px; height: 400px;
  background: radial-gradient(circle, rgba(5,150,105,0.08) 0%, transparent 70%);
  pointer-events: none;
}
body::after {
  content: '';
  position: fixed;
  bottom: -100px; left: -100px;
  width: 400px; height: 400px;
  background: radial-gradient(circle, rgba(16,185,129,0.06) 0%, transparent 70%);
  pointer-events: none;
}
.login-wrap {
  width: 100%;
  max-width: 380px;
  animation: fadeUp 0.5s ease both;
}
@keyframes fadeUp {
  from { opacity: 0; transform: translateY(20px); }
  to   { opacity: 1; transform: translateY(0); }
}
.login-card {
  background: white;
  border-radius: 22px;
  padding: 36px 30px 32px;
  box-shadow: 0 8px 40px rgba(0,0,0,0.10);
  border: 1px solid rgba(255,255,255,0.8);
}
.logo-wrap {
  text-align: center;
  margin-bottom: 6px;
}
.logo-icon {
  width: 64px; height: 64px;
  background: linear-gradient(135deg, #3a6b1a, #059669);
  border-radius: 18px;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 6px 20px rgba(5,150,105,0.35);
  margin-bottom: 14px;
}
.logo-icon svg { width: 32px; height: 32px; }
.login-title {
  font-size: 20px;
  font-weight: 900;
  color: var(--text);
  text-align: center;
  letter-spacing: -0.5px;
  margin-bottom: 4px;
}
.login-sub {
  font-size: 12px;
  color: var(--muted);
  font-weight: 500;
  text-align: center;
  margin-bottom: 28px;
}
.divider {
  height: 1px;
  background: var(--border);
  margin-bottom: 24px;
}
.form-group { margin-bottom: 14px; }
.form-label {
  font-size: 10px;
  font-weight: 800;
  color: var(--muted);
  text-transform: uppercase;
  letter-spacing: 0.8px;
  margin-bottom: 6px;
  display: block;
}
.input-wrap { position: relative; }
.input-icon {
  position: absolute;
  left: 12px; top: 50%;
  transform: translateY(-50%);
  width: 15px; height: 15px;
  color: #cbd5e1;
  pointer-events: none;
}
.form-input {
  width: 100%;
  padding: 11px 12px 11px 36px;
  border-radius: 11px;
  border: 2px solid var(--border);
  font-size: 13px;
  font-weight: 600;
  font-family: inherit;
  outline: none;
  background: #f8fafc;
  transition: 0.2s;
  color: var(--text);
}
.form-input:focus {
  border-color: var(--primary);
  background: white;
  box-shadow: 0 0 0 3px rgba(5,150,105,0.1);
}
.pw-toggle {
  position: absolute;
  right: 11px; top: 50%;
  transform: translateY(-50%);
  background: none;
  border: none;
  cursor: pointer;
  color: var(--muted);
  font-size: 14px;
  padding: 2px;
  display: flex; align-items: center;
}
.error-box {
  background: #fee2e2;
  border: 1px solid #fca5a5;
  border-radius: 10px;
  padding: 10px 13px;
  font-size: 12px;
  font-weight: 700;
  color: #991b1b;
  margin-bottom: 14px;
  display: none;
  align-items: center;
  gap: 7px;
  animation: shake 0.4s ease;
}
@keyframes shake {
  0%,100%{transform:translateX(0)}
  20%{transform:translateX(-5px)}
  40%{transform:translateX(5px)}
  60%{transform:translateX(-3px)}
  80%{transform:translateX(3px)}
}
.btn-login {
  width: 100%;
  padding: 12px;
  border-radius: 12px;
  background: linear-gradient(135deg, var(--primary), #10b981);
  color: white;
  font-size: 13.5px;
  font-weight: 800;
  border: none;
  cursor: pointer;
  font-family: inherit;
  transition: all 0.2s;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8px;
  box-shadow: 0 4px 14px rgba(5,150,105,0.35);
  margin-top: 4px;
  letter-spacing: 0.3px;
}
.btn-login:hover {
  transform: translateY(-1px);
  box-shadow: 0 6px 20px rgba(5,150,105,0.45);
}
.btn-login:active { transform: translateY(0); }
.btn-login:disabled { opacity: 0.6; cursor: not-allowed; transform: none; }
.spinner {
  width: 16px; height: 16px;
  border: 2.5px solid rgba(255,255,255,0.3);
  border-top-color: white;
  border-radius: 50%;
  animation: spin 0.7s linear infinite;
  display: none;
}
@keyframes spin { to { transform: rotate(360deg); } }
.login-footer {
  text-align: center;
  margin-top: 20px;
  font-size: 10.5px;
  color: var(--muted);
  font-weight: 500;
}
.retry-info {
  font-size: 10px;
  color: var(--muted);
  text-align: center;
  margin-top: 8px;
  display: none;
}
</style>
</head>
<body>

